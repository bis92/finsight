# Public config — Supabase Dashboard > Project Settings > API; project URL (client-visible).
NEXT_PUBLIC_SUPABASE_URL=<supabase-project-url>
# Public config — Supabase Dashboard > Project Settings > API; anon key protected by RLS (client-visible).
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>
# Public config — deployed FinSight origin used for server-generated checkout return URLs (client-visible).
NEXT_PUBLIC_SITE_URL=<deployed-site-origin>

# Server-only secret — Supabase Dashboard > Project Settings > API; Polar webhook plan updates only.
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>
# Server-only secret — Anthropic Console; Claude API access.
ANTHROPIC_API_KEY=<anthropic-api-key>
# Server-only secret — Polar organization settings; server API access.
POLAR_ACCESS_TOKEN=<polar-access-token>
# Server-only secret — Polar webhook endpoint settings; signature verification.
POLAR_WEBHOOK_SECRET=<polar-webhook-signing-secret>
# Server-only config — Polar product catalog; Pro checkout product identifier.
POLAR_PRODUCT_ID=<polar-pro-product-id>

# Server-side data-source switch: mock (default) or live. Change to live only after live setup is verified.
DATA_SOURCE=mock
